# Copy to .env and fill in. Never commit .env.

# Your Telegram numeric user ID (from @userinfobot). Only this user can talk to the bot.
ALLOWED_TELEGRAM_USER_ID=

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Which LLM parses messages: gemini | openai | claude
LLM_PROVIDER=claude
LLM_API_KEY=

# DynamoDB table name (must match var.dynamodb_table_name in Terraform).
DYNAMODB_TABLE_NAME=crypto-ledger

# Currency used for PnL reporting.
BASE_CURRENCY=USD

# AWS region for Terraform (also picked up by boto3 for local invocation).
AWS_REGION=eu-central-1
